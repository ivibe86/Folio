FROM node:20-slim@sha256:2cf067cfed83d5ea958367df9f966191a942351a2df77d6f0193e162b5febfc0

WORKDIR /app

ARG DEPENDENCY_COOLDOWN_DAYS=7
ARG PIP_VERSION=26.0.1

RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip ca-certificates && \
    update-ca-certificates && \
    rm -rf /var/lib/apt/lists/*

COPY backend/requirements.lock /app/backend/requirements.lock
RUN python3 -m pip install --no-cache-dir --break-system-packages --upgrade "pip==${PIP_VERSION}" && \
    cutoff="$(DEPENDENCY_COOLDOWN_DAYS="${DEPENDENCY_COOLDOWN_DAYS}" python3 -c "from datetime import datetime, timezone, timedelta; import os; days = int(os.environ['DEPENDENCY_COOLDOWN_DAYS']); print((datetime.now(timezone.utc) - timedelta(days=days)).replace(microsecond=0).isoformat().replace('+00:00', 'Z'))")" && \
    python3 -m pip install --no-cache-dir --break-system-packages --require-hashes --uploaded-prior-to "$cutoff" -r /app/backend/requirements.lock

COPY frontend/package.json frontend/package-lock.json /app/frontend/
RUN cd /app/frontend && \
    cutoff="$(DEPENDENCY_COOLDOWN_DAYS="${DEPENDENCY_COOLDOWN_DAYS}" node -e "const days = Number(process.env.DEPENDENCY_COOLDOWN_DAYS || 7); console.log(new Date(Date.now() - days * 24 * 60 * 60 * 1000).toISOString())")" && \
    npm ci --before="$cutoff"

COPY . /app

RUN cd /app/frontend && DOCKER=true VITE_API_KEY=folio-demo-key npm run build

RUN chmod +x /app/scripts/run-demo.sh

ENV PORT=3000
EXPOSE 3000

CMD ["/app/scripts/run-demo.sh"]
