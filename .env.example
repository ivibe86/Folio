# ══════════════════════════════════════════════════════════════
# Folio Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env
# Or run: python3 setup.py (interactive guided setup)
# ══════════════════════════════════════════════════════════════

# ── Teller Certificates (required) ── Free 
# Get these from https://teller.io — mTLS certificate pair
# For Docker: place files in ./certs/ and use paths like certs/teller-cert.pem
# For local:  use absolute or relative paths to your .pem files
TELLER_CERT_PATH=certs/teller-cert.pem
TELLER_KEY_PATH=certs/teller-key.pem

# ── Teller Connect (for dynamic enrollment via the "+" button) ── Free 
# Get your Application ID from https://teller.io/dashboard
TELLER_APPLICATION_ID=app_xxxxxxxxxx
TELLER_ENVIRONMENT=development

# ── Token Encryption (required for DB storage) ──
#Generate one: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your-fernet-key-here

# ── Security ──
# API key to protect your backend. Auto-generated if blank.
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
Folio_API_KEY=

# ── Frontend (Vite reads VITE_ prefixed vars) ──
# Should match Folio_API_KEY above
VITE_API_KEY=

# ── Feature Toggles ( Change true to false if you want to opt out ) ──
ENABLE_TROVE=true
ENABLE_LLM_CATEGORIZATION=true
COPILOT_MAX_WRITE_ROWS=5000

# ── Anthropic API Key (optional) ── Paid 
# Powers AI categorization and the copilot feature
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Trove Merchant Enrichment (optional) ── Free 
# Identifies merchants from raw bank descriptions
# Get a key at: https://trove.headline.com/
TROVE_API_KEY=
TROVE_USER_SEED=Folio-self-hosted

#If manually setting up Teller Access Tokens (required — at least one) ──
# Format: FIRSTNAME_BANKNAME_TOKEN=token_value
# The part before the first underscore becomes the profile name.
# Examples:
#   JOHN_BOFA_TOKEN=test_tok_abc123     → profile "john"
#   JOHN_CHASE_TOKEN=test_tok_def456    → profile "john"
#   SARAH_AMEX_TOKEN=test_tok_ghi789    → profile "sarah"
# Uncomment and fill in:
# YOURNAME_BANKNAME_TOKEN=

# ── CORS (defaults work for most setups) ──
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Docker Settings ──
BACKEND_PORT=8000
FRONTEND_PORT=3000
DB_FILE=Folio.db