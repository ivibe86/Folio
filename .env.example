# ==============================================================
# Folio Configuration
# Copy this file to .env and fill in your values, or run:
#   python3 setup.py
# to generate a matching .env interactively.
# ==============================================================

# -----------------------------------------------------------------
# AI Modes
# -----------------------------------------------------------------
# Mode A: Local AI (recommended)
#   LLM_PROVIDER=ollama
#   ENABLE_LOCAL_ENRICHMENT=true
#   ENABLE_LLM_CATEGORIZATION=true
#   OLLAMA_BASE_URL=http://host.docker.internal:11434   # Docker runtime
#   OLLAMA_BASE_URL=http://localhost:11434              # Local dev runtime
#
# Mode B: Cloud AI (bring your own API key)
#   LLM_PROVIDER=anthropic
#   ENABLE_LOCAL_ENRICHMENT=false
#   ENABLE_LLM_CATEGORIZATION=true
#   ANTHROPIC_API_KEY=...
#   Optional: ENABLE_TROVE=true and TROVE_API_KEY=...
#
# Mode C: No AI
#   ENABLE_LOCAL_ENRICHMENT=false
#   ENABLE_LLM_CATEGORIZATION=false
#   ENABLE_TROVE=false
#
# On macOS and Windows, Local AI expects Ollama to run natively on the host OS.
# The backend container connects to it through host.docker.internal.

# -----------------------------------------------------------------
# Teller Certificates (required)
# -----------------------------------------------------------------
# Get these from https://teller.io — mTLS certificate pair
# Docker runtime: place files in ./certs and keep the defaults below.
# Local runtime:  you can use absolute or relative paths.
TELLER_CERT_PATH=certs/teller-cert.pem
TELLER_KEY_PATH=certs/teller-key.pem

# -----------------------------------------------------------------
# Teller Connect (optional but recommended)
# -----------------------------------------------------------------
# Lets users link accounts from the UI with the "+" button.
TELLER_APPLICATION_ID=
TELLER_ENVIRONMENT=sandbox

# -----------------------------------------------------------------
# Token Encryption (required)
# -----------------------------------------------------------------
# Generate one:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# -----------------------------------------------------------------
# Teller Access Tokens (legacy / manual)
# -----------------------------------------------------------------
# Format: FIRSTNAME_BANKNAME_TOKEN=token_value
# The part before the first underscore becomes the profile name.
# Examples:
#   JOHN_BOFA_TOKEN=test_tok_abc123
#   JOHN_CHASE_TOKEN=test_tok_def456
#   SARAH_AMEX_TOKEN=test_tok_ghi789
# Uncomment and fill in as needed:
# YOURNAME_BANKNAME_TOKEN=

# -----------------------------------------------------------------
# Security
# -----------------------------------------------------------------
# API key for backend authentication. VITE_API_KEY should match.
Folio_API_KEY=
VITE_API_KEY=

# -----------------------------------------------------------------
# Feature Toggles
# -----------------------------------------------------------------
DEMO_MODE=false
ENABLE_TROVE=false
ENABLE_LOCAL_ENRICHMENT=true
ENABLE_LLM_CATEGORIZATION=true
COPILOT_MAX_WRITE_ROWS=5000
# Dispatcher/specialist Copilot is enabled by default.
# Temporary emergency escape hatch for one release cycle:
# COPILOT_USE_LEGACY_AGENT=true

# -----------------------------------------------------------------
# LLM Provider
# -----------------------------------------------------------------
# Use "ollama" for Local AI, "anthropic" for Cloud AI.
LLM_PROVIDER=ollama

# -----------------------------------------------------------------
# Ollama (Local AI mode)
# -----------------------------------------------------------------
# For Docker runtime on macOS/Windows:
OLLAMA_BASE_URL=http://host.docker.internal:11434
#
# For local development runtime:
# OLLAMA_BASE_URL=http://localhost:11434

# Suggested presets:
# Light
# OLLAMA_MODEL_CATEGORIZE=gemma4:e2b
# OLLAMA_MODEL_COPILOT=gemma4:e2b
#
# Balanced
OLLAMA_MODEL_CATEGORIZE=gemma4:e4b
OLLAMA_MODEL_COPILOT=gemma4:e4b
#
# Best Quality
# OLLAMA_MODEL_CATEGORIZE=gemma4:e4b
# OLLAMA_MODEL_COPILOT=gemma4:26b

# Number of merchant descriptions to normalize per enrichment call.
LOCAL_ENRICHMENT_BATCH_SIZE=20
# Minimum accepted confidence from local merchant normalization: low|medium|high
LOCAL_ENRICHMENT_MIN_CONFIDENCE=medium
# Timeouts in seconds. Increase if your hardware is slower.
OLLAMA_TIMEOUT_CATEGORIZE=600
OLLAMA_TIMEOUT_COPILOT=240

# -----------------------------------------------------------------
# Cloud AI (Mode B)
# -----------------------------------------------------------------
# Used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------
# Trove Merchant Enrichment (optional)
# -----------------------------------------------------------------
# Optional cloud merchant enrichment. Keep disabled if you want a fully local stack.
TROVE_API_KEY=
TROVE_USER_SEED=Folio-self-hosted

# -----------------------------------------------------------------
# Frontend / App Settings
# -----------------------------------------------------------------
VITE_TELLER_APP_ID=
VITE_TELLER_ENVIRONMENT=sandbox
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------
# Docker Settings
# -----------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000
DB_FILE=Folio.db
TRUSTED_HOSTS=localhost,127.0.0.1,backend
